<?xml version='1.0' encoding='utf-8'?>
<widget id="com.icumanager.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>ICU Manager</name>
    <description>ICU Patient Management System</description>
    <author email="admin@icumanager.com" href="http://161.35.216.33">ICU Manager Team</author>
    <content src="index.html" />

    <!-- Allow all intents and navigation to the backend server -->
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-navigation href="*" />
    <access origin="*" />

    <!-- Android preferences -->
    <platform name="android">
        <edit-config file="app/src/main/AndroidManifest.xml" mode="merge" target="/manifest/application">
            <application android:usesCleartextTraffic="true" />
        </edit-config>
        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-compileSdkVersion" value="35" />
        <preference name="android-targetSdkVersion" value="34" />
        <preference name="AndroidWindowSoftInputMode" value="adjustResize" />
        <preference name="scheme" value="http" />
        <preference name="hostname" value="localhost" />
        <preference name="MixedContentMode" value="0" />
        <preference name="AllowNavigation" value="*" />
        <preference name="AllowMixedContent" value="true" />
    </platform>

    <!-- General WebView preferences -->
    <preference name="DisallowOverscroll" value="false" />
    <preference name="Fullscreen" value="false" />
    <preference name="SplashScreenDelay" value="1000" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="ShowSplashScreenSpinner" value="false" />

    <!-- Allow loading mixed http content from https context -->
    <preference name="CordovaWebViewEngine" value="org.apache.cordova.engine.SystemWebViewEngine" />
</widget>
