<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarAddMed"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#0F172A"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:title="Prescribe Medication"
            app:titleTextColor="#FFFFFF" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Medication Name with autocomplete -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Medication Name *"
                android:textColor="#475569"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <AutoCompleteTextView
                android:id="@+id/editMedName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_bg"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:hint="Type or select common drug..."
                android:padding="14dp"
                android:textSize="15sp"
                android:completionThreshold="1"
                android:layout_marginBottom="4dp"/>

            <!-- Drug suggestions list (shown programmatically) -->
            <ListView
                android:id="@+id/listDrugSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

            <!-- Dose -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dose *"
                android:textColor="#475569"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editMedDose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_bg"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:hint="e.g. 1g, 500mg"
                android:padding="14dp"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <!-- Route Spinner -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Route *"
                android:textColor="#475569"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinnerRoute"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/edit_text_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp"/>

            <!-- Frequency Spinner -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Frequency *"
                android:textColor="#475569"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinnerFrequency"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/edit_text_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp"/>

            <!-- Start Date -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Date *"
                android:textColor="#475569"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <Button
                android:id="@+id/btnStartDate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="#F1F5F9"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:gravity="start|center_vertical"
                android:paddingStart="14dp"
                android:layout_marginBottom="12dp"
                android:text="Select date"/>

            <!-- Infusion Rate -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Infusion Rate (Optional)"
                android:textColor="#475569"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editMedInfusionRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_bg"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:hint="e.g. 5ml/hr"
                android:padding="14dp"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <!-- Dilution -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dilution – Total Volume (mL, Optional)"
                android:textColor="#475569"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editMedDilution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_bg"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:hint="e.g. 50 (for mg/50cc)"
                android:padding="14dp"
                android:textSize="15sp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="12dp"/>

            <!-- Duration Reminder -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Duration Reminder (Days, Optional)"
                android:textColor="#475569"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editMedReminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_bg"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:hint="e.g. 3"
                android:padding="14dp"
                android:textSize="15sp"
                android:inputType="number"
                android:layout_marginBottom="12dp"/>

            <!-- Other Instructions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Other Instructions (Optional)"
                android:textColor="#475569"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editMedInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_bg"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:hint="Optional details..."
                android:padding="14dp"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"/>

            <ProgressBar
                android:id="@+id/progressSubmitMed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnSubmitMed"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:backgroundTint="#3B82F6"
                android:text="Prescribe"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
