<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Abnormal Lab Alert Banner -->
        <LinearLayout
            android:id="@+id/layoutAbnormalAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#7F1D1D"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#9888;"
                android:textColor="#FCA5A5"
                android:textSize="18sp"
                android:layout_marginEnd="8dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Abnormal Investigation Results Detected"
                    android:textColor="#FCA5A5"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/textAbnormalDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FECACA"
                    android:textSize="11sp"
                    android:text="Review required"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 1: Vitals + Fluid Balance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:weightSum="2">

            <!-- Vitals Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardBackgroundColor="#1E293B"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="VITALS"
                            android:textColor="#94A3B8"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/textVitalsDelayed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DELAYED"
                            android:background="#7F1D1D"
                            android:textColor="#FCA5A5"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="2dp"
                            android:visibility="gone"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/textVitalsBP"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--/-- mmHg"
                        android:textColor="#F8FAFC"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView
                            android:id="@+id/textVitalsHR"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="HR: --"
                            android:textColor="#F87171"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/textVitalsSpo2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="SpO2: --%"
                            android:textColor="#60A5FA"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/textVitalsTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No records"
                        android:textColor="#64748B"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Fluid Balance Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardBackgroundColor="#1E293B"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="12h BALANCE"
                        android:textColor="#94A3B8"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/textBalance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="+0 mL"
                        android:textColor="#34D399"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">
                        <TextView
                            android:id="@+id/textTotalIn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="In: 0"
                            android:textColor="#60A5FA"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/textTotalOut"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Out: 0"
                            android:textColor="#F59E0B"
                            android:textSize="11sp"/>
                    </LinearLayout>
                    <ProgressBar
                        android:id="@+id/progressBalance"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:max="100"
                        android:progress="50"
                        android:progressTint="#3B82F6"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Active Support Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE INFUSION SUPPORT"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:id="@+id/layoutActiveSupport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/textNoSupport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No active infusions"
                        android:textColor="#64748B"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Clinical Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CLINICAL INFO"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PRIMARY DIAGNOSIS"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/textOverviewDiagnosis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp"
                    android:text="Loading..."
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="10dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="COMORBIDITIES (PMH)"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/textOverviewComorbidities"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FCD34D"
                    android:textSize="13sp"
                    android:text="Loading..."
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="10dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="ADMITTED"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/textOverviewAdmitted"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#F8FAFC"
                            android:textSize="13sp"
                            android:text="--"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="ADMITTING DOCTOR"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/textOverviewDoctor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#F8FAFC"
                            android:textSize="13sp"
                            android:text="--"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Recent Activity Timeline -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="RECENT ACTIVITY"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
                <TextView
                    android:id="@+id/textNoTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No recent activity recorded"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
