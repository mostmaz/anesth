<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardInvestigation"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginHorizontal="4dp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header: type badge + abnormal badge + date + delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textInvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingEnd="8dp"
                android:textAllCaps="true"
                android:textColor="#3B82F6"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textAbnormalBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABNORMAL"
                android:textColor="#FCA5A5"
                android:background="#7F1D1D"
                android:textSize="9sp"
                android:textStyle="bold"
                android:paddingHorizontal="5dp"
                android:paddingVertical="2dp"
                android:layout_marginEnd="6dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/textInvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textColor="#94A3B8"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#7F1D1D"
                android:text="X"
                android:textColor="#FCA5A5"
                android:textSize="10sp"
                android:padding="0dp"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/textInvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:textColor="#F8FAFC"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/dividerResult"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="6dp"
            android:background="#334155"
            android:visibility="gone" />

        <!-- Column headers for structured results -->
        <LinearLayout
            android:id="@+id/layoutResultHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:visibility="gone">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2"
                android:text="Test" android:textColor="#64748B" android:textSize="10sp" android:textStyle="bold" android:textAllCaps="true"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2"
                android:text="Result" android:textColor="#64748B" android:textSize="10sp" android:textStyle="bold" android:textAllCaps="true"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2"
                android:gravity="end" android:text="Range" android:textColor="#64748B" android:textSize="10sp" android:textStyle="bold" android:textAllCaps="true"/>
        </LinearLayout>

        <!-- Dynamic result rows -->
        <LinearLayout
            android:id="@+id/layoutResultRows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Plain text impression fallback -->
        <TextView
            android:id="@+id/textInvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:lineSpacingMultiplier="1.4"
            android:textColor="#CBD5E1"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- View Image/Report Button -->
        <Button
            android:id="@+id/btnViewReport"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#1E40AF"
            android:paddingHorizontal="12dp"
            android:text="View Report"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
