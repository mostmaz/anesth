<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginEnd="4dp"
    android:layout_marginStart="4dp"
    android:layout_marginTop="4dp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header row: type badge + date + view report button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textInvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingEnd="8dp"
                android:textAllCaps="true"
                android:textColor="#3B82F6"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textInvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnViewReport"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#1E40AF"
                android:paddingHorizontal="10dp"
                android:text="View Report"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- Study / test title -->
        <TextView
            android:id="@+id/textInvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="4dp"
            android:textColor="#F8FAFC"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Thin divider shown only when there are results -->
        <View
            android:id="@+id/dividerResult"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="8dp"
            android:background="#334155"
            android:visibility="gone" />

        <!-- Column headers (shown only when there are structured results) -->
        <LinearLayout
            android:id="@+id/layoutResultHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Test"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Result"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:gravity="end"
                android:text="Reference"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- Dynamic result rows injected by the adapter -->
        <LinearLayout
            android:id="@+id/layoutResultRows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Fallback for plain-text impression / notes -->
        <TextView
            android:id="@+id/textInvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:lineSpacingMultiplier="1.4"
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
