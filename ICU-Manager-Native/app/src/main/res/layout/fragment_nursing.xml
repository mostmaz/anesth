<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Skin Assessment Records"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1E293B" />

        <Button
            android:id="@+id/btnAddSkinAssessment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add Assessment"
            android:textSize="12sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0" />

    <ProgressBar
        android:id="@+id/progressNursing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/textNursingEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No skin assessments recorded yet.\nTap 'Add Assessment' to document skin status."
        android:textAlignment="center"
        android:textColor="#9CA3AF"
        android:textSize="14sp"
        android:padding="32dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSkinAssessments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false" />

</LinearLayout>
