<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:id="@+id/layoutNotificationInner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/viewStatusIndicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:background="#3B82F6"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textNotificationTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New Investigation Result"
                android:textColor="#F1F5F9"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textNotificationPatient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Patient: John Doe"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/textNotificationTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="10 minutes ago"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imageArrow"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_media_play"
            app:tint="#475569"
            android:layout_marginStart="8dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
