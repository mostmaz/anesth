<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <ProgressBar
            android:id="@+id/progressAssignments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone" />

        <!-- Pending Assignments Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending Approval"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/textPendingEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No pending assignment requests."
            android:textColor="#9CA3AF"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#F8FAFC"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPendingAssignments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="20dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            android:layout_marginBottom="16dp" />

        <!-- Active Assignments Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active Assignments"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textActiveEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No active nurse assignments."
            android:textColor="#9CA3AF"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#F8FAFC"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerActiveAssignments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>

</ScrollView>
