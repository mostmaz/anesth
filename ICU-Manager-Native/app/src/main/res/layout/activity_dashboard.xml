<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E293B"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="ICU Dashboard"
            app:titleTextColor="#FFFFFF" />

        <!-- Active Shift Banner -->
        <LinearLayout
            android:id="@+id/layoutActiveShift"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#10B981"
            android:padding="8dp"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/presence_online"
                app:tint="#FFFFFF"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/textShiftStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active Shift"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center"
            android:background="#0F172A">

            <Button
                android:id="@+id/btnStartShift"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start Shift"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3B82F6"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnEndShift"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="End Shift"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#EF4444"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnShiftHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="History"
                android:textSize="12sp"
                android:textColor="#94A3B8"
                android:backgroundTint="#334155"
                android:layout_marginStart="4dp" />

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Loading / Error -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:indeterminateTint="#3B82F6"
                android:visibility="visible" />

            <TextView
                android:id="@+id/textError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#EF4444"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone" />

            <!-- ── INTERVENTION REMINDERS SECTION ── -->
            <LinearLayout
                android:id="@+id/layoutReminders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="#162032"
                android:layout_margin="8dp"
                android:padding="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        android:tint="#F59E0B"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intervention Reminders"
                        android:textColor="#F59E0B"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewReminders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <!-- ── CLINICAL ORDERS SECTION ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="8dp"
                android:background="#1E293B"
                android:padding="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Clinical Orders"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"/>

                <!-- Tab buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp">

                    <Button
                        android:id="@+id/btnTabActive"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Active"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#3B82F6"
                        android:layout_marginEnd="4dp"/>

                    <Button
                        android:id="@+id/btnTabRecent"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Recent"
                        android:textSize="11sp"
                        android:textColor="#94A3B8"
                        android:backgroundTint="#334155"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"/>

                    <Button
                        android:id="@+id/btnTabCompleted"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Done"
                        android:textSize="11sp"
                        android:textColor="#94A3B8"
                        android:backgroundTint="#334155"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/textNoOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No orders to display."
                    android:textColor="#64748B"
                    android:gravity="center"
                    android:padding="16dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ── PATIENT LIST SECTION ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="My Patients"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewPatients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddPatient"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        app:backgroundTint="#3B82F6"
        app:tint="#FFFFFF"
        android:src="@android:drawable/ic_input_add" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
