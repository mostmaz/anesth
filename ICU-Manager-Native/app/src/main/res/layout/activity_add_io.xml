<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarAddIo"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#0F172A"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:title="Record I/O"
            app:titleTextColor="#FFFFFF" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Type"
                android:textColor="#334155"
                android:textSize="14sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/radioInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Input"
                    android:buttonTint="#3B82F6"
                    android:textColor="#0F172A"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/radioOutput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Output"
                    android:buttonTint="#F59E0B"
                    android:textColor="#0F172A" />
            </RadioGroup>

            <!-- Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Category"
                android:textColor="#334155"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <!-- Fluid / Source -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Fluid / Source"
                android:textColor="#334155"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editFluidType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_bg"
                android:hint="e.g. Normal Saline, Urine, Blood"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A" />

            <!-- Amount -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Amount (mL)"
                android:textColor="#334155"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editAmount"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_bg"
                android:hint="e.g. 500"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A" />

            <!-- Rate (optional, for continuous infusions) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Rate (mL/hr) — optional"
                android:textColor="#334155"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editRate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_bg"
                android:hint="e.g. 50"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A" />

            <!-- Notes -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Notes — optional"
                android:textColor="#334155"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editIoNotes"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/edit_text_bg"
                android:gravity="top|start"
                android:hint="Additional notes..."
                android:inputType="textMultiLine"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:textColor="#0F172A" />

            <ProgressBar
                android:id="@+id/progressSubmitIo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnSubmitIo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#3B82F6"
                android:text="Save Record"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
