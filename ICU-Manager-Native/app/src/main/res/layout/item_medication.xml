<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginTop="4dp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/textMedName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F8FAFC"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/textMedDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/textMedInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#3B82F6"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textMedMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F43F5E"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnStopMed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#F43F5E"
                android:text="Stop"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:visibility="gone" />

            <View
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btnRecordDose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#10B981"
                android:text="Record Dose"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
