<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A">

    <!-- Header + Search row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E293B"
        android:padding="12dp">

        <TextView
            android:id="@+id/textInvestigationsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lab Results"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editSearch"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:hint="Search by test name..."
            android:textColorHint="#475569"
            android:textColor="#F8FAFC"
            android:background="#0F172A"
            android:paddingHorizontal="12dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewInvestigations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddInvestigation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_menu_upload"
        android:tint="#FFFFFF"
        android:backgroundTint="#3B82F6"
        android:contentDescription="Upload Result" />

</LinearLayout>
